{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic user profile information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "staff", "member"], "description": "The user's role in the party." },
        "partyRole": { "type": "string", "description": "Specific leadership role (e.g., 'President', 'Secretary')." },
        "committeeId": { "type": "string", "description": "The ID of the committee the user belongs to." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Committee": {
      "title": "Committee",
      "description": "Party committee at various levels of the hierarchy.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the committee." },
        "level": { "type": "string", "enum": ["central", "province", "district", "municipality", "ward", "wing"], "description": "Level of the committee." },
        "province": { "type": "string", "description": "Province (if applicable)." },
        "district": { "type": "string", "description": "District (if applicable)." },
        "localLevel": { "type": "string", "description": "Municipality/Rural Municipality (if applicable)." },
        "ward": { "type": "integer", "description": "Ward number (if applicable)." },
        "parentId": { "type": "string", "description": "ID of the parent committee." }
      },
      "required": ["name", "level"]
    },
    "PartyMember": {
      "title": "Party Member",
      "description": "Detailed information about a party member.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string", "description": "Unique party identifier for the member." },
        "fullName": { "type": "string", "description": "Full legal name of the member." },
        "email": { "type": "string", "format": "email", "description": "Contact email." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "province": { "type": "string", "description": "Province in Nepal (1-7)." },
        "district": { "type": "string", "description": "District in Nepal." },
        "localLevel": { "type": "string", "description": "Municipality or Rural Municipality." },
        "ward": { "type": "integer", "description": "Ward number." },
        "joiningDate": { "type": "string", "format": "date", "description": "Date the member joined the party." },
        "status": { "type": "string", "enum": ["active", "inactive", "suspended"], "description": "Current membership status." },
        "addedBy": { "type": "string", "description": "UID of the user who added this member." },
        "qrCode": { "type": "string", "description": "Unique QR code string for verification." }
      },
      "required": ["fullName", "joiningDate", "status", "province", "district"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Record of income (fees, donations) or expenses.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Type of transaction." },
        "category": { "type": "string", "enum": ["fee", "donation", "campaign", "administrative", "other"], "description": "Category of transaction." },
        "amount": { "type": "number", "description": "Amount in NPR." },
        "date": { "type": "string", "format": "date-time", "description": "When the transaction occurred." },
        "description": { "type": "string", "description": "Details of the transaction." },
        "recordedBy": { "type": "string", "description": "UID of the user who recorded this." }
      },
      "required": ["type", "category", "amount", "date"]
    },
    "Grievance": {
      "title": "Grievance",
      "description": "Complaint or grievance submitted by a member or citizen.",
      "type": "object",
      "properties": {
        "subject": { "type": "string", "description": "Subject of the grievance." },
        "description": { "type": "string", "description": "Detailed description." },
        "submittedBy": { "type": "string", "description": "Name or UID of the submitter." },
        "status": { "type": "string", "enum": ["pending", "in-review", "resolved", "closed"], "description": "Current status." },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Priority level." },
        "date": { "type": "string", "format": "date-time", "description": "When it was submitted." }
      },
      "required": ["subject", "description", "status", "date"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Record of sensitive actions taken in the system.",
      "type": "object",
      "properties": {
        "action": { "type": "string", "description": "The action performed (e.g., 'MEMBER_DELETE')." },
        "performedBy": { "type": "string", "description": "UID of the user who performed the action." },
        "details": { "type": "string", "description": "Additional details about the action." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred." }
      },
      "required": ["action", "performedBy", "timestamp"]
    },
    "PartyDocument": {
      "title": "Party Document",
      "description": "Party-related documents and files.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the document." },
        "description": { "type": "string", "description": "Brief description." },
        "category": { "type": "string", "enum": ["policy", "legal", "manifesto", "finance", "other"], "description": "Category of the document." },
        "fileUrl": { "type": "string", "description": "URL to the stored file." },
        "fileName": { "type": "string", "description": "Original name of the file." },
        "fileType": { "type": "string", "description": "MIME type of the file." },
        "uploadedBy": { "type": "string", "description": "UID of the uploader." },
        "uploadedAt": { "type": "string", "format": "date-time", "description": "When the document was uploaded." },
        "size": { "type": "integer", "description": "Size of the file in bytes." }
      },
      "required": ["title", "category", "fileUrl", "fileName", "fileType", "uploadedBy", "uploadedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "UserProfile", "description": "User profiles and roles." },
    "/committees/{committeeId}": { "schema": "Committee", "description": "Party committees." },
    "/members/{memberId}": { "schema": "PartyMember", "description": "Party membership records." },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial records." },
    "/grievances/{grievanceId}": { "schema": "Grievance", "description": "Complaint records." },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "System audit logs." },
    "/events/{eventId}": { "schema": "Event", "description": "Party events." },
    "/candidates/{candidateId}": { "schema": "Candidate", "description": "Election candidates." },
    "/documents/{docId}": { "schema": "PartyDocument", "description": "Party documents and files." }
  }
}

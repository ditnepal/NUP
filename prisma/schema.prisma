generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                     @id @default(uuid())
  email                String                     @unique
  passwordHash         String?
  displayName          String
  phoneNumber          String?
  role                 String                     @default("MEMBER")
  isActive             Boolean                    @default(true)
  roleId               String?
  orgUnitId            String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  createdAppEvents     AppEvent[]                 @relation("AppEventAuthor")
  attendance           Attendance[]
  auditLogs            AuditLog[]
  boothTeams           BoothTeamMember[]
  certificates         Certificate[]
  uploadedMedia        CmsMedia[]                 @relation("MediaUploader")
  createdPages         CmsPage[]                  @relation("PageAuthor")
  createdPosts         CmsPost[]                  @relation("PostAuthor")
  deliveryLogs         DeliveryLog[]
  donorProfile         DonorProfile?
  incidentReports      ElectionIncident[]         @relation("IncidentReporter")
  enrollments          Enrollment[]
  eventRegistrations   EventRegistration[]
  grievances           Grievance[]                @relation("GrievanceReporter")
  assignedGrievances   GrievanceAssignment[]
  grievanceResponses   GrievanceResponse[]
  fieldReports         GroundIntelligenceReport[]
  intelligenceAlerts   IntelligenceAlert[]
  memberProfile        Member?
  verifiedMembers      Member[]                   @relation("MemberVerifier")
  approvedMembers      Member[]                   @relation("MemberApprover")
  notices              Notice[]
  notifications        Notification[]
  officeBearers        OfficeBearer[]
  outreachRecords      OutreachRecord[]
  pollVotes            PollVote[]
  quizAttempts         QuizAttempt[]
  surveyResponses      SurveyResponse[]
  reviewedTransactions Transaction[]              @relation("TransactionReviewer")
  recordedTransactions Transaction[]              @relation("TransactionRecorder")
  cmsSections          CmsSection[]               @relation("SectionAuthor")
  roleProfile          Role?                      @relation(fields: [roleId], references: [id])
  orgUnit              OrganizationUnit?          @relation(fields: [orgUnitId], references: [id])
  volunteerProfile     Volunteer?
  deployments          VolunteerDeployment[]

  @@index([roleId])
  @@index([orgUnitId])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id        String   @id @default(uuid())
  action    String
  resource  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     Role[]   @relation("PermissionToRole")
}

model OrganizationUnit {
  id                  String                     @id @default(uuid())
  name                String
  level               String
  code                String?                    @unique
  parentId            String?
  isActive            Boolean                    @default(true)
  description         String?
  sortOrder           Int                        @default(0)
  contactEmail        String?
  contactPhone        String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  areaStrengthScore   AreaStrengthScore?
  booths              Booth[]
  committees          Committee[]
  communityPriorities CommunityPriority[]
  departments         Department[]
  grievances          Grievance[]
  fieldReports        GroundIntelligenceReport[]
  intelligenceAlerts  IntelligenceAlert[]
  members             Member[]
  offices             Office[]
  parent              OrganizationUnit?          @relation("Hierarchy", fields: [parentId], references: [id])
  children            OrganizationUnit[]         @relation("Hierarchy")
  users               User[]
  wings               Wing[]
  electionCycles      ElectionCycle[]
  constituencies      Constituency[]
  candidates          Candidate[]
  pollingStations     PollingStation[]
  incidents           ElectionIncident[]
  results             ElectionResult[]
  surveys             Survey[]
  polls               Poll[]
  fundraisingCampaigns FundraisingCampaign[]
  transactions        Transaction[]
  campaigns           Campaign[]
}

model Office {
  id            String           @id @default(uuid())
  name          String
  type          String
  orgUnitId     String
  address       String
  contactNumber String?
  email         String?
  latitude      Float?
  longitude     Float?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  orgUnit       OrganizationUnit @relation(fields: [orgUnitId], references: [id])
}

model Committee {
  id          String           @id @default(uuid())
  name        String
  type        String
  description String?
  isActive    Boolean          @default(true)
  orgUnitId   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orgUnit     OrganizationUnit @relation(fields: [orgUnitId], references: [id])
  bearers     OfficeBearer[]
}

model OfficeBearer {
  id          String    @id @default(uuid())
  committeeId String
  userId      String?
  fullName    String
  position    String
  termStart   DateTime
  termEnd     DateTime?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  committee   Committee @relation(fields: [committeeId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
}

model Department {
  id          String           @id @default(uuid())
  name        String
  description String?
  orgUnitId   String
  headId      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orgUnit     OrganizationUnit @relation(fields: [orgUnitId], references: [id])
}

model Wing {
  id          String           @id @default(uuid())
  name        String
  description String?
  orgUnitId   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orgUnit     OrganizationUnit @relation(fields: [orgUnitId], references: [id])
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  status    String   @default("UNREAD")
  link      String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String?
  entityId   String?
  details    String?
  userId     String?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([entityType, entityId])
}

model MembershipType {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String?
  fee            Float
  durationMonths Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  members        Member[]
}

model Member {
  id                     String            @id @default(uuid())
  userId                 String?           @unique
  membershipId           String?           @unique
  trackingCode           String            @unique
  fullName               String
  dateOfBirth            DateTime?
  gender                 String?
  bloodGroup             String?
  citizenshipNumber      String?           @unique
  province               String?
  district               String?
  localLevel             String?
  ward                   Int?
  boothId                String?
  orgUnitId              String?
  committeeLevel         String?
  committeeRole          String?
  joinedDate             DateTime?
  expiryDate             DateTime?
  status                 String            @default("PENDING")
  fatherName             String?
  motherName             String?
  citizenshipDistrict    String?
  citizenshipIssueDate   DateTime?
  tole                   String?
  mobile                 String?
  email                  String?
  alternateContactName   String?
  alternateContactMobile String?
  occupation             String?
  applicationMode        String            @default("FORM")
  videoUrl               String?
  identityDocumentUrl    String?
  identityDocumentType   String?
  profilePhotoUrl        String?
  helperName             String?
  helperPhone            String?
  helperRole             String?
  paymentMethod          String?
  membershipTypeId       String?
  suspensionHistory      String?
  terminationHistory     String?
  verifiedById           String?
  verifiedAt             DateTime?
  approvedById           String?
  approvedAt             DateTime?
  reviewNote             String?
  isEscalated            Boolean           @default(false)
  escalatedAt            DateTime?
  escalatedToUnitId      String?
  escalationNote         String?
  qrCodeData             String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  user                   User?             @relation(fields: [userId], references: [id])
  booth                  Booth?            @relation(fields: [boothId], references: [id])
  orgUnit                OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
  membershipType         MembershipType?   @relation(fields: [membershipTypeId], references: [id])
  verifiedBy             User?             @relation("MemberVerifier", fields: [verifiedById], references: [id])
  approvedBy             User?             @relation("MemberApprover", fields: [approvedById], references: [id])
  renewalRequests        RenewalRequest[]
  transactions           Transaction[]
  volunteer              Volunteer?
}

model RenewalRequest {
  id            String        @id @default(uuid())
  memberId      String
  status        String        @default("PENDING")
  memberNote    String?
  adminNote     String?
  paymentMethod String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  member        Member        @relation(fields: [memberId], references: [id])
  transactions  Transaction[]
}

model Volunteer {
  id               String                   @id @default(uuid())
  memberId         String?                  @unique
  userId           String?                  @unique
  fullName         String
  email            String?
  phone            String?
  skills           String
  availability     String?
  status           String                   @default("ACTIVE")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  member           Member?                  @relation(fields: [memberId], references: [id])
  user             User?                    @relation(fields: [userId], references: [id])
  assignments      VolunteerAssignment[]
  availabilityList VolunteerAvailability[]
  performance      VolunteerPerformance[]
  recognitions     VolunteerRecognition[]
  skillsList       VolunteerSkill[]
  statusHistory    VolunteerStatusHistory[]
}

model VolunteerApplication {
  id           String   @id @default(uuid())
  fullName     String
  email        String
  phone        String
  skills       String
  availability String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VolunteerSkill {
  id          String    @id @default(uuid())
  volunteerId String
  skill       String
  createdAt   DateTime  @default(now())
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

model VolunteerAvailability {
  id          String    @id @default(uuid())
  volunteerId String
  dayOfWeek   String
  startTime   String
  endTime     String
  createdAt   DateTime  @default(now())
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

model VolunteerRecognition {
  id          String    @id @default(uuid())
  volunteerId String
  title       String
  description String
  date        DateTime  @default(now())
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

model VolunteerPerformance {
  id          String    @id @default(uuid())
  volunteerId String
  rating      Int
  feedback    String
  createdAt   DateTime  @default(now())
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

model VolunteerStatusHistory {
  id          String    @id @default(uuid())
  volunteerId String
  status      String
  changedAt   DateTime  @default(now())
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

model VolunteerAssignment {
  id          String            @id @default(uuid())
  volunteerId String
  campaignId  String?
  taskName    String
  description String?
  status      String            @default("PENDING")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  volunteer   Volunteer         @relation(fields: [volunteerId], references: [id])
  campaign    Campaign?         @relation(fields: [campaignId], references: [id])
  reports     VolunteerReport[]
}

model VolunteerReport {
  id           String              @id @default(uuid())
  assignmentId String
  content      String
  hoursSpent   Float?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  assignment   VolunteerAssignment @relation(fields: [assignmentId], references: [id])
}

model Supporter {
  id              String           @id @default(uuid())
  fullName        String
  phoneNumber     String?
  email           String?
  province        String
  district        String
  localLevel      String
  ward            Int
  boothId         String?
  supportLevel    String           @default("NEUTRAL")
  issues          String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  interactions    Interaction[]
  outreachRecords OutreachRecord[]
  booth           Booth?           @relation(fields: [boothId], references: [id])
}

model Interaction {
  id          String    @id @default(uuid())
  supporterId String
  type        String
  date        DateTime  @default(now())
  notes       String?
  handledBy   String
  createdAt   DateTime  @default(now())
  supporter   Supporter @relation(fields: [supporterId], references: [id], onDelete: Cascade)
}

model CmsPage {
  id             String   @id @default(uuid())
  slug           String   @unique
  title          String
  content        String
  status         String   @default("DRAFT")
  authorId       String
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  language       String   @default("en")
  isSystem       Boolean  @default(false)
  isPinned       Boolean  @default(false)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  author         User     @relation("PageAuthor", fields: [authorId], references: [id])
}

model CmsPost {
  id             String       @id @default(uuid())
  slug           String       @unique
  title          String
  excerpt        String?
  content        String
  type           String       @default("NEWS")
  status         String       @default("DRAFT")
  authorId       String
  categoryId     String?
  featuredImage  String?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  language       String       @default("en")
  isPinned       Boolean      @default(false)
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         User         @relation("PostAuthor", fields: [authorId], references: [id])
  category       CmsCategory? @relation(fields: [categoryId], references: [id])
}

model CmsCategory {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  type        String     @default("POST")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  media       CmsMedia[]
  posts       CmsPost[]
}

model CmsMedia {
  id           String       @id @default(uuid())
  title        String
  fileName     String
  fileType     String
  mimeType     String
  url          String
  size         Int
  categoryId   String?
  uploadedById String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  category     CmsCategory? @relation(fields: [categoryId], references: [id])
  uploadedBy   User         @relation("MediaUploader", fields: [uploadedById], references: [id])
}

model CmsRedirect {
  id         String   @id @default(uuid())
  fromPath   String   @unique
  toPath     String
  statusCode Int      @default(301)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CmsDownload {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String
  fileType    String
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CmsSection {
  id          String   @id @default(cuid())
  title       String
  type        String   // HERO, HIGHLIGHT, CTA, CONTENT_BLOCK, NOTICE_BANNER
  order       Int      @default(0)
  isEnabled   Boolean  @default(true)
  content     String   // JSON string for type-specific content
  authorId    String
  author      User     @relation("SectionAuthor", fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       CmsSectionContent[]
}

model CmsSectionContent {
  id          String   @id @default(cuid())
  sectionId   String
  section     CmsSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  contentId   String   // ID of the related content (CmsPost, Notice, etc.)
  contentType String   // POST, NOTICE, EVENT, etc.
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Issue {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  priority    String   @default("MEDIUM")
  status      String   @default("OPEN")
  reporterId  String?
  contactInfo String?
  province    String?
  district    String?
  localLevel  String?
  ward        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id                   String                @id @default(uuid())
  name                 String
  title                String?
  description          String?
  type                 String?
  phase                String                @default("PLANNING")
  status               String?
  startDate            DateTime?
  endDate              DateTime?
  targetProvince       String?
  targetDistrict       String?
  targetLocalLevel     String?
  targetAudience       String?
  budget               Float?
  managerId            String?
  orgUnitId            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  volunteerAssignments VolunteerAssignment[]
  orgUnit              OrganizationUnit?     @relation(fields: [orgUnitId], references: [id])
}

model ElectionCycle {
  id         String             @id @default(uuid())
  name       String
  year       Int
  type       String
  status     String             @default("UPCOMING")
  startDate  DateTime?
  endDate    DateTime?
  orgUnitId  String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  candidates Candidate[]
  incidents  ElectionIncident[]
  results    ElectionResult[]
  orgUnit    OrganizationUnit?  @relation(fields: [orgUnitId], references: [id])
}

model Constituency {
  id              String           @id @default(uuid())
  name            String
  code            String?          @unique
  type            String
  province        String
  district        String
  totalVoters     Int              @default(0)
  orgUnitId       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  candidates      Candidate[]
  results         ElectionResult[]
  pollingStations PollingStation[]
  orgUnit         OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
}

model Candidate {
  id              String              @id @default(uuid())
  name            String
  position        String
  electionCycleId String?
  constituencyId  String?
  electionType    String?
  electionYear    Int?
  province        String?
  district        String?
  localLevel      String?
  ward            Int?
  manifesto       String?
  status          String              @default("ACTIVE")
  orgUnitId       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  electionCycle   ElectionCycle?      @relation(fields: [electionCycleId], references: [id])
  constituency    Constituency?       @relation(fields: [constituencyId], references: [id])
  orgUnit         OrganizationUnit?   @relation(fields: [orgUnitId], references: [id])
  documents       CandidateDocument[]
  results         ElectionResult[]
}

model CandidateDocument {
  id          String    @id @default(uuid())
  candidateId String
  title       String
  type        String
  fileUrl     String
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id])
}

model PollingStation {
  id             String             @id @default(uuid())
  name           String
  code           String?            @unique
  location       String
  constituencyId String?
  ward           Int
  localLevel     String
  district       String
  province       String
  orgUnitId      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  booths         Booth[]
  incidents      ElectionIncident[]
  constituency   Constituency?      @relation(fields: [constituencyId], references: [id])
  orgUnit        OrganizationUnit?  @relation(fields: [orgUnitId], references: [id])
}

model Booth {
  id               String                @id @default(uuid())
  name             String
  code             String?               @unique
  pollingStationId String?
  ward             Int
  localLevel       String
  district         String
  province         String?
  totalVoters      Int                   @default(0)
  voterCount       Int?
  targetVotes      Int                   @default(0)
  status           String                @default("NEEDS_ATTENTION")
  readinessNote    String?
  coordinatorId    String?
  orgUnitId        String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  pollingStation   PollingStation?       @relation(fields: [pollingStationId], references: [id])
  orgUnit          OrganizationUnit?     @relation(fields: [orgUnitId], references: [id])
  team             BoothTeamMember[]
  results          ElectionResult[]
  members          Member[]
  outreach         OutreachRecord[]
  pollingLogs      PollingDayLog[]
  supporters       Supporter[]
  deployments      VolunteerDeployment[]
  incidents        ElectionIncident[]
}

model BoothTeamMember {
  id        String   @id @default(uuid())
  boothId   String
  userId    String
  role      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booth     Booth    @relation(fields: [boothId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([boothId, userId])
}

model VolunteerDeployment {
  id        String    @id @default(uuid())
  boothId   String
  userId    String
  startDate DateTime
  endDate   DateTime?
  task      String?
  status    String    @default("ASSIGNED")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  booth     Booth     @relation(fields: [boothId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model OutreachRecord {
  id          String     @id @default(uuid())
  boothId     String
  userId      String
  supporterId String?
  type        String
  outcome     String?
  notes       String?
  createdAt   DateTime   @default(now())
  booth       Booth      @relation(fields: [boothId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  supporter   Supporter? @relation(fields: [supporterId], references: [id])
}

model PollingDayLog {
  id               String   @id @default(uuid())
  boothId          String
  timestamp        DateTime @default(now())
  voterTurnout     Int?
  incidentOccurred Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  booth            Booth    @relation(fields: [boothId], references: [id])
}

model ElectionIncident {
  id               String          @id @default(uuid())
  cycleId          String
  pollingStationId String?
  boothId          String?
  reporterId       String
  type             String
  severity         String          @default("MEDIUM")
  description      String
  status           String          @default("REPORTED")
  orgUnitId        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  cycle            ElectionCycle   @relation(fields: [cycleId], references: [id])
  pollingStation   PollingStation? @relation(fields: [pollingStationId], references: [id])
  booth            Booth?          @relation(fields: [boothId], references: [id])
  reporter         User            @relation("IncidentReporter", fields: [reporterId], references: [id])
  orgUnit          OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
}

model ElectionResult {
  id             String        @id @default(uuid())
  cycleId        String
  constituencyId String?
  boothId        String?
  candidateId    String
  votesReceived  Int
  isWinner       Boolean       @default(false)
  verifiedById   String?
  verifiedAt     DateTime?
  orgUnitId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cycle          ElectionCycle @relation(fields: [cycleId], references: [id])
  constituency   Constituency? @relation(fields: [constituencyId], references: [id])
  booth          Booth?        @relation(fields: [boothId], references: [id])
  candidate      Candidate     @relation(fields: [candidateId], references: [id])
  orgUnit        OrganizationUnit? @relation(fields: [orgUnitId], references: [id])

  @@unique([cycleId, boothId, candidateId])
}

model Document {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  fileUrl     String
  fileName    String
  fileType    String
  size        Int
  uploadedBy  String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id            String              @id @default(uuid())
  title         String
  description   String?
  type          String
  status        String              @default("PLANNED")
  startDate     DateTime
  endDate       DateTime?
  location      String
  isVirtual     Boolean             @default(false)
  meetingUrl    String?
  capacity      Int?
  organizerId   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  agenda        EventAgenda[]
  registrations EventRegistration[]
  speakers      EventSpeaker[]
}

model EventRegistration {
  id             String    @id @default(uuid())
  eventId        String
  userId         String?
  fullName       String
  email          String
  phone          String?
  status         String    @default("REGISTERED")
  rsvpDate       DateTime  @default(now())
  attendanceDate DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  event          Event     @relation(fields: [eventId], references: [id])
  user           User?     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model EventSpeaker {
  id        String   @id @default(uuid())
  eventId   String
  name      String
  title     String?
  bio       String?
  photoUrl  String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
}

model EventAgenda {
  id          String   @id @default(uuid())
  eventId     String
  startTime   DateTime
  endTime     DateTime
  title       String
  description String?
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id])
}

model FundraisingCampaign {
  id                String              @id @default(uuid())
  title             String
  description       String?
  fundraiserType    String              @default("PARTY_FUND")
  beneficiaryType   String              @default("PARTY")
  candidateId       String?
  candidateSnapshot Json?
  goalAmount        Float
  currentAmount     Float               @default(0)
  startDate         DateTime
  endDate           DateTime?
  status            String              @default("ACTIVE")
  orgUnitId         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  donations         Donation[]
  updates           FundraisingUpdate[]
  orgUnit           OrganizationUnit?   @relation(fields: [orgUnitId], references: [id])
}

model FundraisingUpdate {
  id         String              @id @default(uuid())
  campaignId String
  title      String
  content    String
  createdAt  DateTime            @default(now())
  campaign   FundraisingCampaign @relation(fields: [campaignId], references: [id])
}

model DonorProfile {
  id            String              @id @default(uuid())
  userId        String?             @unique
  fullName      String
  email         String              @unique
  phone         String?
  address       String?
  totalDonated  Float               @default(0)
  donationCount Int                 @default(0)
  isAnonymous   Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  donations     Donation[]
  user          User?               @relation(fields: [userId], references: [id])
  recurring     RecurringDonation[]
}

model Donation {
  id            String               @id @default(uuid())
  donorId       String
  campaignId    String?
  transactionId String               @unique
  amount        Float
  currency      String               @default("NPR")
  status        String               @default("PENDING")
  paymentMethod String?
  isRecurring   Boolean              @default(false)
  recurringId   String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime             @default(now())
  donor         DonorProfile         @relation(fields: [donorId], references: [id])
  campaign      FundraisingCampaign? @relation(fields: [campaignId], references: [id])
  transaction   Transaction          @relation(fields: [transactionId], references: [id])
}

model RecurringDonation {
  id        String       @id @default(uuid())
  donorId   String
  amount    Float
  frequency String
  status    String       @default("ACTIVE")
  startDate DateTime     @default(now())
  nextDate  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  donor     DonorProfile @relation(fields: [donorId], references: [id])
}

model Transaction {
  id                 String          @id @default(uuid())
  type               String
  category           String
  amount             Float
  description        String?
  date               DateTime        @default(now())
  status             String          @default("COMPLETED")
  paymentMethod      String?
  referenceId        String?
  recordedById       String?
  reviewedById       String?
  reviewedAt         DateTime?
  reconciliationNote String?
  orgUnitId          String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  memberId           String?
  renewalRequestId   String?
  donation           Donation?
  renewalRequest     RenewalRequest? @relation(fields: [renewalRequestId], references: [id])
  member             Member?         @relation(fields: [memberId], references: [id])
  reviewedBy         User?           @relation("TransactionReviewer", fields: [reviewedById], references: [id])
  recordedBy         User?           @relation("TransactionRecorder", fields: [recordedById], references: [id])
  orgUnit            OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
}

model PaymentIntegration {
  id               String   @id @default(uuid())
  provider         String
  displayName      String
  region           String
  enabled          Boolean  @default(true)
  mode             String   @default("TEST")
  sortOrder        Int      @default(0)
  supportedModules String
  instructions     String?
  publicKey        String?
  secretRef        String?
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AudienceSegment {
  id          String                  @id @default(uuid())
  name        String
  description String?
  criteria    String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  campaigns   CommunicationCampaign[]
}

model CommunicationTemplate {
  id        String                  @id @default(uuid())
  name      String
  subject   String?
  body      String
  type      String
  category  String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  campaigns CommunicationCampaign[]
}

model CommunicationCampaign {
  id           String                @id @default(uuid())
  name         String
  status       String                @default("DRAFT")
  templateId   String
  segmentId    String?
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  template     CommunicationTemplate @relation(fields: [templateId], references: [id])
  segment      AudienceSegment?      @relation(fields: [segmentId], references: [id])
  deliveryLogs DeliveryLog[]
}

model DeliveryLog {
  id         String                 @id @default(uuid())
  campaignId String?
  userId     String?
  recipient  String
  status     String
  error      String?
  provider   String?
  sentAt     DateTime               @default(now())
  campaign   CommunicationCampaign? @relation(fields: [campaignId], references: [id])
  user       User?                  @relation(fields: [userId], references: [id])
}

model TrainingProgram {
  id            String   @id @default(uuid())
  name          String
  description   String?
  category      String
  status        String   @default("DRAFT")
  audience      String   @default("PUBLIC")
  isPinned      Boolean  @default(false)
  externalUrl   String?
  attachmentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  courses       Course[]
}

model Course {
  id           String          @id @default(uuid())
  programId    String
  title        String
  description  String?
  thumbnail    String?
  level        String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  certificates Certificate[]
  program      TrainingProgram @relation(fields: [programId], references: [id])
  enrollments  Enrollment[]
  lessons      Lesson[]
}

model Lesson {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  content   String
  videoUrl  String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id])
  quizzes   Quiz[]
}

model Quiz {
  id           String         @id @default(uuid())
  lessonId     String
  title        String
  passingScore Int            @default(80)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lesson       Lesson         @relation(fields: [lessonId], references: [id])
  attempts     QuizAttempt[]
  questions    QuizQuestion[]
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  question      String
  options       String
  correctOption Int
  createdAt     DateTime @default(now())
  quiz          Quiz     @relation(fields: [quizId], references: [id])
}

model QuizAttempt {
  id        String   @id @default(uuid())
  quizId    String
  userId    String
  score     Int
  passed    Boolean
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Enrollment {
  id          String    @id @default(uuid())
  courseId    String
  userId      String
  status      String    @default("ENROLLED")
  progress    Float     @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course    @relation(fields: [courseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
}

model Certificate {
  id             String    @id @default(uuid())
  courseId       String
  userId         String
  issueDate      DateTime  @default(now())
  expiryDate     DateTime?
  certificateUrl String?
  createdAt      DateTime  @default(now())
  course         Course    @relation(fields: [courseId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
}

model LiveSession {
  id          String       @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  type        String
  location    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendance  Attendance[]
}

model Attendance {
  id        String      @id @default(uuid())
  sessionId String
  userId    String
  status    String      @default("PRESENT")
  createdAt DateTime    @default(now())
  session   LiveSession @relation(fields: [sessionId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
}

model GrievanceCategory {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  slaHours    Int         @default(48)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  grievances  Grievance[]
}

model Grievance {
  id          String                @id @default(uuid())
  title       String
  description String
  categoryId  String
  reporterId  String
  status      String                @default("OPEN")
  priority    String                @default("MEDIUM")
  orgUnitId   String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  category    GrievanceCategory     @relation(fields: [categoryId], references: [id])
  reporter    User                  @relation("GrievanceReporter", fields: [reporterId], references: [id])
  orgUnit     OrganizationUnit?     @relation(fields: [orgUnitId], references: [id])
  assignments GrievanceAssignment[]
  responses   GrievanceResponse[]

  @@index([status])
  @@index([reporterId])
  @@index([categoryId])
  @@index([orgUnitId])
}

model GrievanceAssignment {
  id          String    @id @default(uuid())
  grievanceId String
  userId      String
  assignedAt  DateTime  @default(now())
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  grievance   Grievance @relation(fields: [grievanceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model GrievanceResponse {
  id          String    @id @default(uuid())
  grievanceId String
  userId      String
  content     String
  isInternal  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  grievance   Grievance @relation(fields: [grievanceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model Survey {
  id            String           @id @default(uuid())
  title         String
  description   String?
  status        String           @default("DRAFT")
  audience      String           @default("MEMBER")
  placementType String           @default("GENERAL")
  targetSlug    String?
  orgUnitId     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  questions     SurveyQuestion[]
  responses     SurveyResponse[]
  orgUnit       OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
}

model SurveyQuestion {
  id        String         @id @default(uuid())
  surveyId  String
  text      String
  type      String
  options   String?
  order     Int
  createdAt DateTime       @default(now())
  answers   SurveyAnswer[]
  survey    Survey         @relation(fields: [surveyId], references: [id])
}

model SurveyResponse {
  id        String         @id @default(uuid())
  surveyId  String
  userId    String?
  createdAt DateTime       @default(now())
  answers   SurveyAnswer[]
  survey    Survey         @relation(fields: [surveyId], references: [id])
  user      User?          @relation(fields: [userId], references: [id])
}

model SurveyAnswer {
  id         String         @id @default(uuid())
  responseId String
  questionId String
  value      String
  createdAt  DateTime       @default(now())
  response   SurveyResponse @relation(fields: [responseId], references: [id])
  question   SurveyQuestion @relation(fields: [questionId], references: [id])
}

model Poll {
  id            String       @id @default(uuid())
  question      String
  status        String       @default("ACTIVE")
  audience      String       @default("MEMBER")
  placementType String       @default("GENERAL")
  targetSlug    String?
  orgUnitId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  options       PollOption[]
  votes         PollVote[]
  orgUnit       OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
}

model PollOption {
  id        String     @id @default(uuid())
  pollId    String
  text      String
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id])
  votes     PollVote[]
}

model PollVote {
  id        String     @id @default(uuid())
  pollId    String
  optionId  String
  userId    String?
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id])
  option    PollOption @relation(fields: [optionId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
}

model GroundIntelligenceReport {
  id             String            @id @default(uuid())
  reporterId     String
  type           String
  content        String
  latitude       Float?
  longitude      Float?
  locationName   String?
  orgUnitId      String?
  sentimentScore Int?
  priority       String            @default("MEDIUM")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  reporter       User              @relation(fields: [reporterId], references: [id])
  orgUnit        OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
}

model CommunityPriority {
  id          String           @id @default(uuid())
  orgUnitId   String
  issue       String
  description String?
  rank        Int              @default(1)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orgUnit     OrganizationUnit @relation(fields: [orgUnitId], references: [id])
}

model IntelligenceAlert {
  id        String            @id @default(uuid())
  title     String
  content   String
  severity  String            @default("MEDIUM")
  orgUnitId String?
  userId    String?
  isRead    Boolean           @default(false)
  createdAt DateTime          @default(now())
  orgUnit   OrganizationUnit? @relation(fields: [orgUnitId], references: [id])
  user      User?             @relation(fields: [userId], references: [id])
}

model AreaStrengthScore {
  id                 String           @id @default(uuid())
  orgUnitId          String           @unique
  partyStrength      Int              @default(0)
  oppositionStrength Int              @default(0)
  swingVoters        Int              @default(0)
  lastUpdated        DateTime         @updatedAt
  orgUnit            OrganizationUnit @relation(fields: [orgUnitId], references: [id])
}

model Notice {
  id            String    @id @default(uuid())
  title         String
  content       String
  audience      String    @default("PUBLIC") // PUBLIC, MEMBERS, STAFF
  status        String    @default("DRAFT")
  isPinned      Boolean   @default(false)
  isPopup       Boolean   @default(false)
  displayType   String    @default("BANNER") // BANNER, MODAL, TOAST
  targetPath    String?   // Optional: target specific pages (e.g., "/dashboard")
  publishAt     DateTime?
  expireAt      DateTime?
  attachmentUrl String?
  externalUrl   String?
  authorId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation(fields: [authorId], references: [id])

  @@index([status, audience])
}

model Contact {
  id        String   @id @default(uuid())
  fullName  String
  email     String?
  phone     String?
  source    String
  sourceId  String?
  tags      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InternalNotice {
  id          String   @id @default(uuid())
  title       String
  content     String
  targetRoles String
  createdAt   DateTime @default(now())
}

model RetryQueue {
  id          String   @id @default(uuid())
  messageId   String
  provider    String
  payload     String
  attempt     Int      @default(0)
  status      String
  nextRetryAt DateTime
  createdAt   DateTime @default(now())
}

model AppEvent {
  id            String   @id @default(uuid())
  title         String
  summary       String?
  description   String
  audience      String   @default("PUBLIC")
  status        String   @default("DRAFT")
  isPinned      Boolean  @default(false)
  eventDate     DateTime
  startAt       String
  endAt         String?
  location      String
  coverImageUrl String?
  attachmentUrl String?
  authorId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  author        User     @relation("AppEventAuthor", fields: [authorId], references: [id])

  @@index([status, audience])
}

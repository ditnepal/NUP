# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="https://ais-dev-ekhrjlebfqeh6655r7migm-189384781482.asia-east1.run.app"

# SHARED_APP_URL: The URL where this applet is shared.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
SHARED_APP_URL="https://ais-pre-ekhrjlebfqeh6655r7migm-189384781482.asia-east1.run.app"

# FIREBASE_API_KEY: Your Firebase project API key.
FIREBASE_API_KEY=""

# FIREBASE_AUTH_DOMAIN: Your Firebase project auth domain.
FIREBASE_AUTH_DOMAIN=""

# FIREBASE_PROJECT_ID: Your Firebase project ID.
FIREBASE_PROJECT_ID=""

# FIREBASE_APP_ID: Your Firebase project app ID.
FIREBASE_APP_ID=""

# FIREBASE_FIRESTORE_DATABASE_ID: Your Firestore database ID (default is '(default)').
FIREBASE_FIRESTORE_DATABASE_ID="(default)"
